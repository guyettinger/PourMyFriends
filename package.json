{
  "name": "pourmyfriends",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "prebuild": "expo prebuild --clean",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --profile production --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:apple": "cp apple.ios.credentials.json credentials.json && eas build --profile apple --platform ios --local",
    "build:apple:preview": "cp apple.ios.credentials.json credentials.json && eas build --profile apple_preview --platform ios --local",
    "build:web": "yarn add eas-cli && eas env:pull --environment preview --non-interactive && expo export -p web",
    "env:development": "eas env:pull --environment development",
    "env:preview": "eas env:pull --environment preview",
    "test": "jest",
    "check:expo": "npx expo-doctor",
    "check:lint": "eslint",
    "check:prettier": "prettier --check --log-level warn ./",
    "postinstall": "npx tailwindcss -i global.css -o ./node_modules/.cache/nativewind/global.css"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.0.14",
    "@rn-primitives/slot": "~1.1.0",
    "@rn-primitives/types": "~1.1.0",
    "clsx": "^2.1.1",
    "dotenv-flow": "^4.1.0",
    "expo": "53.0.20",
    "expo-application": "~6.1.4",
    "expo-build-properties": "~0.14.6",
    "expo-constants": "~17.1.6",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.1",
    "expo-gl": "~15.1.7",
    "expo-image": "~2.4.0",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.5",
    "expo-localization": "~16.1.5",
    "expo-navigation-bar": "~4.2.6",
    "expo-router": "~5.1.4",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.9",
    "expo-updates": "~0.28.15",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "~0.79.5",
    "react-native-drawer-layout": "^4.1.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.0.0",
    "@babel/plugin-proposal-optional-chaining": "^7.0.0",
    "@babel/plugin-transform-arrow-functions": "^7.0.0",
    "@babel/plugin-transform-shorthand-properties": "^7.0.0",
    "@babel/plugin-transform-template-literals": "^7.0.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/i18n-js": "3.8.2",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "babel-jest": "^29.2.1",
    "eslint": "8.17.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-config-standard": "17.0.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "6.0.0",
    "eslint-plugin-react": "7.30.0",
    "eslint-plugin-react-native": "4.0.0",
    "jest": "^29.2.1",
    "jest-expo": "^53.0.9",
    "patch-package": "6.4.7",
    "postinstall-prepare": "1.0.1",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-test-renderer": "19.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [],
        "listUnknownPackages": false
      }
    }
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ]
  },
  "private": true
}
